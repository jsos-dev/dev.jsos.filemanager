{
    "name": "file-manager",
    "version": "0.3.7",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "preview": "vite preview",
        "start": "node server.js",
        "git:tag": "node -e \"const v=require('./package.json').version;const{execSync}=require('child_process');execSync('git tag v'+v+' && git push origin v'+v,{stdio:'inherit'});console.log('Tagged and pushed v'+v)\""
    },
    "repository": {
      "type": "git",
      "url": "https://github.com/jsos-dev/dev.jsos.filemanager"
    },
    "bugs": {
      "url": "https://github.com/jsos-dev/dev.jsos.filemanager/issues"
    },
    "author": {
      "name": "JSOS",
      "url": "https://github.com/jsos-dev"
    },
    "dependencies": {
        "adm-zip": "^0.5.17",
        "archiver": "^8.0.0",
        "express": "^4.18.0",
        "multer": "^2.1.1"
    },
    "devDependencies": {
        "@base-ui/react": "^1.5.0",
        "@codemirror/lang-css": "^6.3.1",
        "@codemirror/lang-html": "^6.4.11",
        "@codemirror/lang-javascript": "^6.2.5",
        "@codemirror/lang-json": "^6.0.2",
        "@codemirror/lang-python": "^6.2.1",
        "@codemirror/theme-one-dark": "^6.1.3",
        "@tailwindcss/vite": "^4.0.0",
        "@uiw/react-codemirror": "^4.25.10",
        "@vitejs/plugin-react": "^4.0.0",
        "class-variance-authority": "^0.7.0",
        "clsx": "^2.0.0",
        "lucide-react": "^1.0.0",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "tailwind-merge": "^3.0.0",
        "tailwindcss": "^4.0.0",
        "tw-animate-css": "^1.4.0",
        "vite": "^6.0.0"
    },
    "jsos": {
        "id": "dev.jsos.filemanager",
        "name": { "en": "File Manager", "zh-CN": "文件" },
        "description": { "en": "A web-based file manager for browsing and managing files", "zh-CN": "基于 Web 的文件管理器，用于浏览和管理文件" },
        "icon": "icon.svg",
        "startCommand": "node server.js",
        "installCommand": "pnpm install",
        "widgets": [
            {
                "id": "disk-info",
                "name": { "en": "Shared Data", "zh-CN": "共享目录" },
                "description": { "en": "Display shared directory statistics", "zh-CN": "显示共享目录文件/目录数量和总大小" },
                "url": "/#/widget/disk-info",
                "cols": 3,
                "rows": 1,
                "background": "frosted"
            },
            {
                "id": "drag-upload",
                "name": { "en": "Quick Upload", "zh-CN": "快速上传" },
                "description": { "en": "Drag & drop files to shared directory", "zh-CN": "拖拽文件上传到共享目录" },
                "url": "/#/widget/drag-upload",
                "cols": 3,
                "rows": 2,
                "background": { "type": "frosted", "opacity": 20, "blur": 3 }
            }
        ]
    }
}
